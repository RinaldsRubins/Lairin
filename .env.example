APP_NAME=Lairin
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Riga
APP_URL=http://localhost:8000
APP_LOCALE=lv
APP_FALLBACK_LOCALE=lv

DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=lairin
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="info@lairin.lv"
MAIL_FROM_NAME="${APP_NAME}"

# Google OAuth2 & Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/admin/google/callback"
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=Europe/Riga
GOOGLE_ADMIN_EMAIL=info@lairin.lv
GOOGLE_MAPS_KEY=
GOOGLE_ANALYTICS_ID=
GOOGLE_SEARCH_CONSOLE_VERIFICATION=

VITE_APP_NAME="${APP_NAME}"
